
#include "stm32f1xx.h"
#include <string.h>

/* ============================================================
 * Configuration Definitions
 * ============================================================ */
#define LCD_ADDR (0x27<<1)
#define RS (1<<0)
#define EN (1<<2)
#define BL (1<<3)

#define CS_HI (GPIOA->BSRR=(1U<<8))
#define CS_LO (GPIOA->BSRR=(1U<<24))

#define SERVO_REST  500
#define SERVO_OPEN  1500

/* Global system ticks for non-blocking timing */
static volatile uint32_t system_ticks = 0;
static uint16_t rain_analog_val = 0;
static uint8_t led_state = 0;

/* ============================================================
 * DELAY (8MHz System Clock)
 * ============================================================ */
static void delay_ms(uint32_t ms)
{ for(;ms>0;ms--) for(volatile uint32_t i=0;i<800;i++); }

static void delay_us(uint32_t us)
{ for(;us>0;us--) for(volatile uint32_t i=0;i<1;i++); }

/* ============================================================
 * I2C2  PB10=SCL  PB11=SDA
 * ============================================================ */
static void i2c_start(void){ I2C2->CR1|=I2C_CR1_START; while(!(I2C2->SR1&I2C_SR1_SB)); }
static void i2c_stop(void) { I2C2->CR1|=I2C_CR1_STOP;  while(I2C2->SR2&I2C_SR2_BUSY); }
static void i2c_addr(uint8_t a){ I2C2->DR=a; while(!(I2C2->SR1&I2C_SR1_ADDR)){;} (void)I2C2->SR1;(void)I2C2->SR2; }
static void i2c_byte(uint8_t d){ while(!(I2C2->SR1&I2C_SR1_TXE)){;} I2C2->DR=d; while(!(I2C2->SR1&I2C_SR1_BTF)){;} }

static void i2c_init(void)
{
    RCC->APB1ENR |= RCC_APB1ENR_I2C2EN;
    I2C2->CR1 |= I2C_CR1_SWRST;
    I2C2->CR1 &= ~I2C_CR1_SWRST;
    I2C2->CR2=8; I2C2->CCR=40; I2C2->TRISE=9;
    I2C2->CR1 |= I2C_CR1_PE;
}

/* ============================================================
 * LCD1602  PCF8574 backpack
 * ============================================================ */
static void pcf(uint8_t d){ i2c_start();i2c_addr(LCD_ADDR);i2c_byte(d);i2c_stop(); }
static void pulse(uint8_t d){ pcf(d|EN|BL);delay_us(1);pcf((d&~EN)|BL);delay_us(50); }
static void nibble(uint8_t n,uint8_t rs){ pulse((n<<4)|(rs?RS:0)); }
static void lcd_cmd(uint8_t c){ nibble(c>>4,0);nibble(c&0xF,0);delay_us(200); }
static void lcd_chr(char c)   { nibble((uint8_t)c>>4,1);nibble((uint8_t)c&0xF,1);delay_us(200); }
static void lcd_str(const char*s){ while(*s)lcd_chr(*s++); }
static void lcd_pos(uint8_t r,uint8_t c){ lcd_cmd((r?0xC0:0x80)+c); }
static void lcd_cls(void){ lcd_cmd(0x01);delay_ms(2); }

static void lcd_init(void)
{
    delay_ms(50);
    nibble(0x03,0);delay_ms(5);
    nibble(0x03,0);delay_ms(1);
    nibble(0x03,0);delay_ms(1);
    nibble(0x02,0);delay_ms(1);
    lcd_cmd(0x28);lcd_cmd(0x0C);
    lcd_cmd(0x06);lcd_cmd(0x01);
    delay_ms(2);
}

/* ============================================================
 * SERVO MOTOR (TIM4 CH2 -> PB7)
 * ============================================================ */
static void servo_init(void)
{
    RCC->APB1ENR |= RCC_APB1ENR_TIM4EN;
    TIM4->PSC = 7;
    TIM4->ARR = 19999;
    TIM4->CCR2 = SERVO_REST;
    TIM4->CCMR1 &= ~(TIM_CCMR1_OC2M | TIM_CCMR1_CC2S);
    TIM4->CCMR1 |= (6U << TIM_CCMR1_OC2M_Pos) | TIM_CCMR1_OC2PE;
    TIM4->CCER  |= TIM_CCER_CC2E;
    TIM4->CR1   |= TIM_CR1_ARPE | TIM_CR1_CEN;
    TIM4->EGR   |= TIM_EGR_UG;
}

static void servo_set_angle(uint16_t pulse_us)
{
    TIM4->CCR2 = pulse_us;
}

/* ============================================================
 * SPI2  PA8=CS  PB13=SCK  PB14=MISO  PB15=MOSI
 * ============================================================ */
static void spi_init(void)
{
    RCC->APB1ENR |= RCC_APB1ENR_SPI2EN;
    SPI2->CR1 = SPI_CR1_MSTR|SPI_CR1_BR_0
              | SPI_CR1_SSM |SPI_CR1_SSI
              | SPI_CR1_CPOL|SPI_CR1_CPHA;
    SPI2->CR1 |= SPI_CR1_SPE;
    CS_HI;
}

static uint8_t spi_xfer(uint8_t d)
{
    while(!(SPI2->SR&SPI_SR_TXE)){;}
    SPI2->DR=d;
    while(!(SPI2->SR&SPI_SR_RXNE)){;}
    return (uint8_t)SPI2->DR;
}

/* ============================================================
 * RC522
 * ============================================================ */
static void rc_wr(uint8_t r,uint8_t v)
{ CS_LO; spi_xfer((r<<1)&0x7E); spi_xfer(v); CS_HI; }

static uint8_t rc_rd(uint8_t r)
{ uint8_t v; CS_LO; spi_xfer(((r<<1)&0x7E)|0x80); v=spi_xfer(0); CS_HI; return v; }

static void rc_init(void)
{
    CS_HI; delay_ms(10);
    rc_wr(0x01,0x0F); delay_ms(100);
    rc_wr(0x2A,0x80); rc_wr(0x2B,0xA9);
    rc_wr(0x2C,0x03); rc_wr(0x2D,0xE8);
    rc_wr(0x11,0x3D); rc_wr(0x14,0x03);
    delay_ms(10);
}

static uint8_t rc_card_here(void)
{
    rc_wr(0x01,0x00); rc_wr(0x02,0x00); rc_wr(0x04,0x7F);
    rc_wr(0x0A,0x80); rc_wr(0x06,0x00); rc_wr(0x0D,0x07);
    rc_wr(0x09,0x26); rc_wr(0x01,0x0C); rc_wr(0x0D,rc_rd(0x0D)|0x80);

    uint16_t to=5000; uint8_t irq;
    do{ irq=rc_rd(0x04); to--; }while(to&&!(irq&0x31));

    rc_wr(0x0D,rc_rd(0x0D)&~0x80); rc_wr(0x01,0x00); rc_wr(0x0D,0x00);

    if(!to||(irq&0x01)||(rc_rd(0x06)&0x1B)) return 0;
    if(rc_rd(0x0A)!=2) return 0;

    uint8_t b0=rc_rd(0x09); uint8_t b1=rc_rd(0x09);
    if(b0==0&&b1==0) return 0;
    return 1;
}

/* ============================================================
 * KEYPAD  Rows PA10,PA11,PA12,PA15   Cols PB3,PB4,PB5
 * ============================================================ */
static const uint8_t ROW[4]={10,11,12,15};
static const uint8_t COL[3]={ 3, 4, 5};
static const char    MAP[4][3]={
    {'1','2','3'},
    {'4','5','6'},
    {'7','8','9'},
    {'*','0','#'}
};

static char kp_scan(void)
{
    for(uint8_t r=0;r<4;r++){
        for(uint8_t x=0;x<4;x++) GPIOA->BSRR=(1U<<ROW[x]);
        GPIOA->BSRR=(1U<<(ROW[r]+16));
        delay_us(500);
        for(uint8_t c=0;c<3;c++){
            if(!((GPIOB->IDR>>COL[c])&1)){
                delay_ms(20);
                if(!((GPIOB->IDR>>COL[c])&1)){
                    while(!((GPIOB->IDR>>COL[c])&1)){;}
                    for(uint8_t x=0;x<4;x++) GPIOA->BSRR=(1U<<ROW[x]);
                    return MAP[r][c];
                }
            }
        }
    }
    for(uint8_t x=0;x<4;x++) GPIOA->BSRR=(1U<<ROW[x]);
    return 0;
}

/* ============================================================
 * ADC1  Channel 6 -> PA6 (Rain Analog)
 * ============================================================ */
static void adc_init(void)
{
    RCC->APB2ENR |= RCC_APB2ENR_ADC1EN;
    ADC1->CR2 |= ADC_CR2_ADON;
    delay_ms(1);
    ADC1->CR2 |= ADC_CR2_CAL;
    while(ADC1->CR2 & ADC_CR2_CAL){;}
    ADC1->SQR1 &= ~ADC_SQR1_L;
    ADC1->SQR3 &= ~ADC_SQR3_SQ1;
    ADC1->SQR3 |= (6U << ADC_SQR3_SQ1_Pos);
}

static uint16_t adc_read_rain(void)
{
    ADC1->CR2 |= ADC_CR2_ADON;
    while(!(ADC1->SR & ADC_SR_EOC)){;}
    return (uint16_t)(ADC1->DR);
}

/* ============================================================
 * BACKGROUND TASKS (PIR, Rain, LED Heartbeat)
 * Unified function so background execution can run anywhere!
 * ============================================================ */
static void update_background_systems(void)
{
    /* -- PIR MOTION SENSOR (PA2) -> LED (PB9) -- */
    uint8_t motion = (GPIOA->IDR >> 2) & 1; /* HIGH = motion */
    if (motion) {
        GPIOB->BSRR = (1U << 9);    /* LED ON */
    } else {
        GPIOB->BRR  = (1U << 9);    /* LED OFF */
    }

    /* -- RAIN SENSOR digital (PA5) -> BUZZER (PA9) -- */
    uint8_t is_raining = !((GPIOA->IDR >> 5) & 1); /* LOW = wet */
    if (is_raining) GPIOA->BSRR = (1U << 9);       /* Buzzer ON */
    else            GPIOA->BRR  = (1U << 9);       /* Buzzer OFF */

    /* -- RAIN analog read (PA6) every 50 ticks -- */
    if (system_ticks % 50 == 0) {
        rain_analog_val = adc_read_rain();
    }

    /* -- Heartbeat LED PC13 (faster blink when raining) -- */
    uint32_t blink_rate = is_raining ? 50 : 200;
    if (system_ticks % blink_rate == 0) {
        led_state ^= 1;
        if (led_state) GPIOC->ODR &= ~(1U << 13);
        else           GPIOC->ODR |=  (1U << 13);
    }
}

/* Non-blocking wrapper for delays that updates sensors while idling */
static void managed_delay_ms(uint32_t ms)
{
    for(uint32_t i = 0; i < ms; i++) {
        delay_ms(1);
        system_ticks++;
        update_background_systems();
    }
}

/* ============================================================
 * SCREENS
 * ============================================================ */
static void scr_menu(void)
{
    lcd_cls();
    lcd_pos(0,0); lcd_str(" 1:PIN  2:CARD  ");
    lcd_pos(1,0); lcd_str(" Choose method: ");
}

static void scr_open(void)
{
    lcd_cls();
    lcd_pos(0,0); lcd_str("    WELCOME :)  ");
    lcd_pos(1,0); lcd_str("    DOOR OPEN   ");
    servo_set_angle(SERVO_OPEN);
    managed_delay_ms(4000);
    servo_set_angle(SERVO_REST);
    scr_menu();
}

static void scr_wrong(void)
{
    lcd_cls();
    lcd_pos(0,0); lcd_str("   WRONG PIN!   ");
    lcd_pos(1,0); lcd_str("   TRY AGAIN    ");
    managed_delay_ms(2000);
    scr_menu();
}

static void scr_card_fail(void)
{
    lcd_cls();
    lcd_pos(0,0); lcd_str(" CARD NOT FOUND ");
    lcd_pos(1,0); lcd_str(" * to go back   ");
}

/* ============================================================
 * MODES
 * ============================================================ */
static uint8_t mode_pin(void)
{
    char buf[5]={0}; uint8_t idx=0;
    lcd_cls();
    lcd_pos(0,0); lcd_str("  Enter PIN:    ");
    lcd_pos(1,0); lcd_str("  PIN:          ");

    while(1)
    {
        managed_delay_ms(1); /* Keeps tracking environmental background updates */
        char key=kp_scan();
        if(!key) continue;
        if(key=='*') return 0;
        else if(key=='#'){/* ignored */}
        else{
            if(idx<4){
                buf[idx++]=key;
                lcd_pos(1,0); lcd_str("  PIN: ");
                for(uint8_t i=0; i<idx; i++) lcd_chr('*');
                for(uint8_t i=idx; i<4; i++) lcd_chr(' ');
                lcd_str("   ");
            }
            if(idx==4){
                buf[4]='\0';
                if(buf[0]=='1'&&buf[1]=='2'&&buf[2]=='3'&&buf[3]=='4'){
                    scr_open(); return 1;
                } else {
                    scr_wrong(); return 0;
                }
            }
        }
    }
}

static void mode_card(void)
{
    lcd_cls();
    lcd_pos(0,0); lcd_str("  Tap your card ");
    lcd_pos(1,0); lcd_str("  * = cancel    ");

    for(uint8_t attempt=0; attempt<50; attempt++)
    {
        if(rc_card_here()){ scr_open(); return; }
        char key=kp_scan();
        if(key=='*') return;
        managed_delay_ms(150); /* keeps PIR active during wait frames */

        lcd_pos(1,0);
        switch(attempt%4){
            case 0: lcd_str("  Scanning .    "); break;
            case 1: lcd_str("  Scanning ..   "); break;
            case 2: lcd_str("  Scanning ...  "); break;
            case 3: lcd_str("  Scanning .... "); break;
        }
    }
    scr_card_fail();
    while(1){ 
        managed_delay_ms(1);
        if(kp_scan()=='*') return; 
    }
}

/* ============================================================
 * MAIN
 * ============================================================ */
int main(void)
{
    /* Enable clocks: GPIOA, GPIOB, GPIOC, AFIO */
    RCC->APB2ENR |= RCC_APB2ENR_IOPAEN | RCC_APB2ENR_IOPBEN
                  | RCC_APB2ENR_IOPCEN  | RCC_APB2ENR_AFIOEN;

    /* Disable JTAG to free PB3/PB4/PA15 */
    AFIO->MAPR &= ~AFIO_MAPR_SWJ_CFG;
    AFIO->MAPR |=  AFIO_MAPR_SWJ_CFG_JTAGDISABLE;

    /* ====================================================
     * GPIOA CRL  (PA0 .. PA7)
     * ==================================================== */
    GPIOA->CRL = (0x4U <<  0)   /* PA0 float */
               | (0x4U <<  4)   /* PA1 float */
               | (0x4U <<  8)   /* PA2 PIR   */
               | (0x4U << 12)   /* PA3 float */
               | (0x4U << 16)   /* PA4 float */
               | (0x8U << 20)   /* PA5 rain D0 pull-up */
               | (0x0U << 24)   /* PA6 rain A0 analog  */
               | (0x4U << 28);  /* PA7 float */
    GPIOA->ODR |= (1U << 5);    /* PA5 pull-up enable  */

    /* ====================================================
     * GPIOA CRH  (PA8 .. PA15)
     * ==================================================== */
    GPIOA->CRH = (0x3U <<  0)   /* PA8  CS      */
               | (0x3U <<  4)   /* PA9  Buzzer  */
               | (0x3U <<  8)   /* PA10 ROW0    */
               | (0x3U << 12)   /* PA11 ROW1    */
               | (0x3U << 16)   /* PA12 ROW2    */
               | (0x4U << 20)   /* PA13 SWDIO - float */
               | (0x4U << 24)   /* PA14 SWCLK - float */
               | (0x3U << 28);  /* PA15 ROW3    */

    /* Keypad rows idle HIGH, CS idle HIGH, Buzzer idle LOW */
    GPIOA->ODR |= (1U<<8)|(1U<<10)|(1U<<11)|(1U<<12)|(1U<<15);
    GPIOA->BRR  = (1U<<9);      /* Buzzer OFF */

    /* ====================================================
     * GPIOB CRL  (PB0 .. PB7)
     * ==================================================== */
    GPIOB->CRL = (0x4U <<  0)   /* PB0 float */
               | (0x4U <<  4)   /* PB1 float */
               | (0x4U <<  8)   /* PB2 float */
               | (0x8U << 12)   /* PB3 COL0 pull-up */
               | (0x8U << 16)   /* PB4 COL1 pull-up */
               | (0x8U << 20)   /* PB5 COL2 pull-up */
               | (0x4U << 24)   /* PB6 float */
               | (0xBU << 28);  /* PB7 TIM4 CH2 AF PP */
    GPIOB->ODR |= (1U<<3)|(1U<<4)|(1U<<5); /* col pull-ups enable */

    /* ====================================================
     * GPIOB CRH  (PB8 .. PB15)
     * ==================================================== */
    GPIOB->CRH = (0x4U <<  0)   /* PB8  float      */
               | (0x3U <<  4)   /* PB9  PIR LED     */
               | (0xFU <<  8)   /* PB10 I2C2 SCL    */
               | (0xFU << 12)   /* PB11 I2C2 SDA    */
               | (0x4U << 16)   /* PB12 float       */
               | (0xBU << 20)   /* PB13 SPI2 SCK    */
               | (0x4U << 24)   /* PB14 SPI2 MISO   */
               | (0xBU << 28);  /* PB15 SPI2 MOSI   */
    GPIOB->BRR = (1U << 9);     /* PIR LED starts OFF */

    /* ====================================================
     * GPIOC CRH  (PC13 = heartbeat LED, active LOW)
     * ==================================================== */
    GPIOC->CRH &= ~(0xFU << 20);
    GPIOC->CRH |=  (0x2U << 20); /* PC13 output 2MHz PP */
    GPIOC->ODR |=  (1U << 13);   /* LED off (active low) */

    /* ====================================================
     * Initialize Peripherals
     * ==================================================== */
    i2c_init();
    delay_ms(200);
    lcd_init();
    spi_init();
    rc_init();
    servo_init();
    adc_init();

    scr_menu();

    /* ====================================================
     * MAIN LOOP
     * ==================================================== */
    while(1)
    {
        managed_delay_ms(1); /* Updates system_ticks, PIR, and Rain sensors */

        /* -- Keypad top-level menu -- */
        char key = kp_scan();
        if (!key) continue;

        if      (key == '1') { mode_pin();  scr_menu(); }
        else if (key == '2') { mode_card(); scr_menu(); }
    }
}
