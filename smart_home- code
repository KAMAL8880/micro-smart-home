#include <Servo.h>

Servo myServo;

void setup() {
    myServo.attach(9);   // Servo signal wire connected to pin 9
    myServo.write(90);   // Set servo to 90 degrees
    delay(1000);
    myServo.write(180);   // Set servo to 90 degrees
    delay(1000);
    myServo.write(90);   // Set servo to 90 degrees



}

void loop() {
    // Nothing needed here
}
